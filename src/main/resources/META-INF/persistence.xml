<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="marketPU" transaction-type="JTA">
        <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>

        <jta-data-source>jdbc/MarketDB</jta-data-source>

        <class>entity.Kullanici</class>
        <class>entity.Kategori</class>
        <class>entity.Urun</class>
        <class>entity.Sepet</class>
        <class>entity.SepetElemani</class>
        <class>entity.Siparis</class>
        <class>entity.SiparisDetay</class>
        <class>entity.Adres</class>
        <class>entity.Favori</class>
        <class>entity.Yorum</class>

        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="none"/>
        </properties>
    </persistence-unit>
</persistence>

